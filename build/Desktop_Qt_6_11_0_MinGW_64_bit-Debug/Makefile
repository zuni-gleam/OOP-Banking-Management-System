	$(MAKE) $(MAKESILENT) -f CMakeFiles\BankingSystem1.dir\build.make CMakeFiles/BankingSystem1.dir/ui/totpdialog.cpp.obj
.PHONY : ui/totpdialog.cpp.obj

ui/totpdialog.i: ui/totpdialog.cpp.i
.PHONY : ui/totpdialog.i

# target to preprocess a source file
ui/totpdialog.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\BankingSystem1.dir\build.make CMakeFiles/BankingSystem1.dir/ui/totpdialog.cpp.i
.PHONY : ui/totpdialog.cpp.i

ui/totpdialog.s: ui/totpdialog.cpp.s
.PHONY : ui/totpdialog.s

# target to generate assembly for a file
ui/totpdialog.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\BankingSystem1.dir\build.make CMakeFiles/BankingSystem1.dir/ui/totpdialog.cpp.s
.PHONY : ui/totpdialog.cpp.s

